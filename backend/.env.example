# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iptv

# Auth
ACCESS_TOKEN_SECRET=change-me-to-a-secure-random-string
REFRESH_TOKEN_SECRET=change-me-to-another-secure-random-string
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Sync
SYNC_INTERVAL_MS=300000
